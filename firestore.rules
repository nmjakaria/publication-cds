rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (getUserData().role == 'admin' || request.auth.token.email == 'nmjakaria01@gmail.com');
    }

    function isStaff() {
      return isSignedIn() && (getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return (isAdmin() || (data.uid == request.auth.uid && data.email == request.auth.token.email)) &&
             data.role in ['admin', 'staff'] &&
             data.keys().hasAll(['uid', 'email', 'name', 'role', 'createdAt']);
    }

    function isValidProduct(data) {
      return data.sku is string && data.sku.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stockLevel is int &&
             data.keys().hasAll(['sku', 'name', 'price', 'stockLevel']);
    }

    function isValidSale(data) {
      return data.invoiceId is string &&
             data.totalAmount is number &&
             data.handledBy == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.keys().hasAll(['invoiceId', 'totalAmount', 'discount', 'items', 'handledBy', 'createdAt', 'customerName', 'paidAmount', 'change']);
    }

    // --- Match Groups ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming()) && (request.auth.token.email == 'nmjakaria01@gmail.com' || isAdmin());
      allow update: if isAdmin() && isValidUser(incoming());
    }

    match /products/{productId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidProduct(incoming());
      allow update: if isStaff() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidSale(incoming());
      allow update, delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAdmin(); // Expenses are usually private to admins
      allow create: if isStaff() && incoming().recordedBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
